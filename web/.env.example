# MusicRAG web runtime
# Copy this to web/.env.local for local Next.js development.

MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority"
MONGODB_DB="music_rag"
MONGODB_SERVER_SELECTION_TIMEOUT_MS="8000"
MONGODB_CONNECT_TIMEOUT_MS="8000"

VOYAGE_API_KEY="<voyage-api-key>"
RERANK_MODEL="rerank-2.5"

# Vercel AI Gateway generation. Vercel deployments can use project OIDC;
# local development can use AI_GATEWAY_API_KEY or a fresh VERCEL_OIDC_TOKEN.
AI_GATEWAY_API_KEY="<optional-vercel-ai-gateway-key>"
VERCEL_OIDC_TOKEN="<optional-short-lived-oidc-token>"
GENERATION_MODEL="google/gemini-3.5-flash"

# Optional expert-mode model list. The server rejects any model not listed here.
AI_GATEWAY_MODEL_ALLOWLIST="google/gemini-3.5-flash"
EXPERT_GENERATION_MODEL="google/gemini-3.5-flash"

# Required only when enabling attachment uploads in Vercel Blob.
BLOB_READ_WRITE_TOKEN="<vercel-blob-token>"
