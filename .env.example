# MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority"
MONGODB_DB="music_rag"

# Local corpus. Keep this outside git.
TRANSCRIPTS_ROOT="../musicindustrytranscripts/transcripts"

# Voyage AI through MongoDB-native model API key
VOYAGE_API_KEY="<atlas-model-api-key>"
EMBED_MODEL="voyage-context-4"
EMBED_FALLBACK_MODEL="voyage-4-large"
EMBED_DIMS="1024"
RERANK_MODEL="rerank-2.5"

# Vercel AI Gateway generation
AI_GATEWAY_API_KEY="<vercel-ai-gateway-key>"
GENERATION_MODEL="google/gemini-3.5-flash"

# Ingestion knobs
CHUNK_TOKENS="500"
CHUNK_OVERLAP="75"
CONTEXT_GROUP_TOKEN_BUDGET="28000"
SCHEMA_VERSION="1"

