# MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority"
# Or use split values so the password can stay in a local secret manager.
MONGODB_HOST="<cluster-host>"
MONGODB_USERNAME="<db-user>"
MONGODB_PASSWORD="<db-password>"
MONGODB_OPTIONS="retryWrites=true&w=majority&appName=musicRAG"
MONGODB_DB="music_rag"

# Local corpus. Keep this outside git.
TRANSCRIPTS_ROOT="../musicindustrytranscripts/transcripts"

# Voyage AI through MongoDB-native model API key
VOYAGE_API_KEY="<atlas-model-api-key>"
EMBED_MODEL="voyage-context-4"
EMBED_FALLBACK_MODEL="voyage-4-large"
EMBED_DIMS="1024"
RERANK_MODEL="rerank-2.5"

# Vercel AI Gateway generation. Vercel deployments can use project OIDC;
# use AI_GATEWAY_API_KEY or VERCEL_OIDC_TOKEN for local/CI runs.
AI_GATEWAY_API_KEY="<optional-vercel-ai-gateway-key>"
VERCEL_OIDC_TOKEN="<optional-short-lived-oidc-token>"
GENERATION_MODEL="google/gemini-3.5-flash"
AI_GATEWAY_MODEL_ALLOWLIST="google/gemini-3.5-flash"
EXPERT_GENERATION_MODEL="google/gemini-3.5-flash"

# Required for web attachment uploads.
BLOB_READ_WRITE_TOKEN="<optional-vercel-blob-token>"

# Ingestion knobs
CHUNK_TOKENS="500"
CHUNK_OVERLAP="75"
CONTEXT_GROUP_TOKEN_BUDGET="28000"
SCHEMA_VERSION="1"
